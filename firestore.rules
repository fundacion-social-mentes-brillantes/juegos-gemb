rules_version = '2';

// ============================================================================
// Reglas de seguridad de Cloud Firestore — Juegos GEMB
// Publícalas en: Firebase Console → Firestore Database → pestaña "Reglas".
// (La base se creó en modo producción = todo denegado; con estas reglas la app
//  funciona y a la vez los datos quedan protegidos.)
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Perfil de cada usuario: cada quien lee/escribe SOLO el suyo ---
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Diario de reflexiones: privado de cada usuario
      match /reflexiones/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // --- Tablas de posiciones (ranking) por juego ---
    // leaderboard/{juego}/entries/{uid}
    // Cualquier usuario autenticado puede VER el ranking.
    // Cada persona solo puede escribir su PROPIO puntaje (doc con su uid).
    match /leaderboard/{game}/entries/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }
  }
}
