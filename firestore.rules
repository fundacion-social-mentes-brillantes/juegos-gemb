rules_version = '2';

// ============================================================================
// Reglas de seguridad de Cloud Firestore — Juegos GEMB  (v4, auditadas)
// Publícalas en: Firebase Console → Firestore Database → pestaña "Reglas".
// v4: perfil privado (solo el dueño lo lee), validación estricta de datos,
// tope de puntaje universal, solo se puede MEJORAR el propio récord,
// hora del servidor obligatoria. SIN lista blanca de juegos: cualquier juego
// NUEVO con ranking funciona automáticamente (no hay que tocar las reglas).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Perfil: SOLO su dueño lo lee y escribe (sin email: no se guarda) ---
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
                   && request.resource.data.keys().hasOnly(['name','photo','lastSeen'])
                   && request.resource.data.name is string
                   && request.resource.data.name.size() > 0
                   && request.resource.data.name.size() <= 60
                   && request.resource.data.photo is string
                   && request.resource.data.photo.size() <= 500
                   && (request.resource.data.photo == '' || request.resource.data.photo.matches('https://.*'));
      allow delete: if request.auth != null && request.auth.uid == uid;

      // Diario de reflexiones: privado; solo crear/leer/borrar (nunca editar)
      match /reflexiones/{docId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.keys().hasOnly(['prompt','texto','createdAt'])
                      && request.resource.data.prompt is string
                      && request.resource.data.prompt.size() <= 500
                      && request.resource.data.texto is string
                      && request.resource.data.texto.size() > 0
                      && request.resource.data.texto.size() <= 5000
                      && request.resource.data.createdAt == request.time;
        allow update: if false;
      }
    }

    // --- Ranking: leaderboard/{juego}/entries/{uid} ---
    match /leaderboard/{game}/entries/{uid} {

      function validEntry() {
        return request.resource.data.keys().hasOnly(['uid','name','photo','score','updatedAt'])
          && request.resource.data.uid == uid
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 60
          && request.resource.data.photo is string
          && request.resource.data.photo.size() <= 500
          && (request.resource.data.photo == '' || request.resource.data.photo.matches('https://.*'))
          && request.resource.data.score is int
          && request.resource.data.score >= 0
          && request.resource.data.score <= 1000000
          && request.resource.data.updatedAt == request.time
          && game.size() > 0 && game.size() <= 40;
      }

      // Cualquier usuario autenticado puede VER el ranking
      allow read: if request.auth != null;
      // Solo puedes crear TU entrada, con datos válidos
      allow create: if request.auth != null && request.auth.uid == uid && validEntry();
      // Solo puedes MEJORAR tu propio récord (nunca bajarlo ni manipularlo)
      allow update: if request.auth != null && request.auth.uid == uid && validEntry()
                    && request.resource.data.score > resource.data.score;
      allow delete: if false;
    }
  }
}
